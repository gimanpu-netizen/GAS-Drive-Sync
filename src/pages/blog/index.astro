---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description="ケンジのブログ記事一覧。AI・自動化・生活設計・マレーシア移住など。" />
  </head>

  <body class="fade-in">
    <Header />

    <main class="container-wide" style="padding-top:48px;padding-bottom:80px;">
      <div class="section-label">すべての記事</div>

      <div class="mag-grid">
        {posts.length === 0 && (
          <p style="grid-column:1/-1;padding:40px;color:var(--fg-dim);font-size:13px;">
            記事は準備中です。
          </p>
        )}
        {posts.length > 0 && (
          <>
            <!-- Large card: first post -->
            <a class="mag-card large" href={`/blog/${posts[0].id}/`}>
              <div class="mag-card-img-wrap" style="flex:1">
                {posts[0].data.heroImage
                  ? <img class="mag-card-img"
                      src={typeof posts[0].data.heroImage === 'string' ? posts[0].data.heroImage : (posts[0].data.heroImage as any).src}
                      alt={posts[0].data.title} />
                  : <div style="width:100%;height:100%;background:linear-gradient(135deg,rgba(59,130,246,0.2),rgba(201,168,76,0.1));"></div>
                }
              </div>
              <div class="mag-card-body">
                <div class="card-category">{posts[0].data.category ?? posts[0].data.tags?.[0] ?? 'Blog'}</div>
                <h2 class="card-title">{posts[0].data.title}</h2>
                <p class="card-desc">{posts[0].data.description}</p>
                <div class="card-meta">
                  <span>{posts[0].data.pubDate.toLocaleDateString('ja-JP')}</span>
                  {posts[0].data.readTime && <span>読了 {posts[0].data.readTime} 分</span>}
                </div>
              </div>
            </a>
            <!-- Remaining posts as small cards -->
            {posts.slice(1).map((post) => (
              <a class="mag-card" href={`/blog/${post.id}/`}>
                <div class="mag-card-img-wrap">
                  {post.data.heroImage
                    ? <img class="mag-card-img"
                        src={typeof post.data.heroImage === 'string' ? post.data.heroImage : (post.data.heroImage as any).src}
                        alt={post.data.title} />
                    : <div style="width:100%;height:100%;background:linear-gradient(135deg,rgba(59,130,246,0.15),rgba(201,168,76,0.08));"></div>
                  }
                </div>
                <div class="mag-card-body">
                  <div class="card-category">{post.data.category ?? post.data.tags?.[0] ?? 'Blog'}</div>
                  <h2 class="card-title">{post.data.title}</h2>
                  <div class="card-meta">
                    <span>{post.data.pubDate.toLocaleDateString('ja-JP')}</span>
                    {post.data.readTime && <span>読了 {post.data.readTime} 分</span>}
                  </div>
                  <div style="margin-top:12px;display:flex;gap:6px;flex-wrap:wrap;">
                    {post.data.tags?.map((t: string) => <span class="card-tag">#{t}</span>)}
                  </div>
                </div>
              </a>
            ))}
          </>
        )}
      </div>
    </main>

    <Footer />
  </body>
</html>
